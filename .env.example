# Copy this file to ".env" and fill in the two values from your Supabase project:
#   Supabase dashboard -> Project Settings -> API
#
# These are PUBLIC values (they ship inside the built JavaScript). That is normal
# for Supabase — your data is protected by Row Level Security, NOT by hiding these.
# Never put the "service_role" secret key here.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
